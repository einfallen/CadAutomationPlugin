# EditorConfig for CadAutomationPlugin
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = crlf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
# C# 代码风格规则
csharp_style_var_for_built_in_types = false
csharp_style_var_when_type_is_apparent = true
csharp_style_var_elsewhere = false
csharp_style_braces_for_if_else = true
csharp_style_braces_for_for = true
csharp_style_braces_for_foreach = true
csharp_style_braces_for_while = true
csharp_style_braces_for_do = true
csharp_style_braces_for_switch = true
csharp_style_braces_for_methods = true
csharp_style_braces_for_properties = true
csharp_style_braces_for_accessors = true
csharp_style_namespace_declarations = file_scoped
csharp_style_prefer_top_level_statements = false
csharp_style_prefer_method_group_conversion = true
csharp_style_prefer_auto_properties = true
csharp_style_prefer_conditional_expression_over_if = true
csharp_style_prefer_conditional_expression_over_assignment = true
csharp_style_prefer_pattern_matching = true
csharp_style_prefer_not_pattern = true
csharp_style_prefer_is_null_check = true
csharp_style_prefer_is_empty_check = true
csharp_style_throw_expression = true
csharp_style_prefer_null_conditional_operator = true
csharp_style_prefer_index_operator = true
csharp_style_prefer_range_operator = true
csharp_style_implicit_object_creation_when_type_is_apparent = true
csharp_style_prefer_tuple_swap = true
csharp_style_deconstructed_variable_declaration = true
csharp_style_prefer_simplified_interpolation = true
csharp_style_prefer_simplified_boolean_expressions = true
csharp_style_inlined_variable_declaration = true
csharp_style_expression_bodied_methods = when_on_single_line
csharp_style_expression_bodied_constructors = when_on_single_line
csharp_style_expression_bodied_operators = when_on_single_line
csharp_style_expression_bodied_properties = when_on_single_line
csharp_style_expression_bodied_indexers = when_on_single_line
csharp_style_expression_bodied_accessors = when_on_single_line
csharp_style_expression_bodied_lambdas = when_on_single_line
csharp_style_expression_bodied_local_functions = when_on_single_line
csharp_style_prefer_local_over_anonymous_function = true
csharp_style_prefer_local_function = true
csharp_style_allow_embedded_statements_on_same_line = false
csharp_style_allow_blank_lines_between_consecutive_braces = false
csharp_style_allow_blank_space_within_multiline_binary_expression = false
csharp_style_prefer_simple_using_statement = true
csharp_style_unused_value_expression_statement_preference = discard_variable
csharp_style_unused_value_assignment_preference = discard_variable
csharp_style_prefer_utf8_string_literals = true
csharp_style_prefer_readonly_struct = true
csharp_style_prefer_readonly_ref_struct = true
csharp_style_prefer_managed_pointer = true

# C# 命名规则
csharp_naming_style.pascal_case.capitalization = pascal_case
csharp_naming_style.camel_case.capitalization = camel_case
csharp_naming_style.upper_case.capitalization = upper_case

csharp_naming_rule.private_instance_fields.capitalization = camel_case
csharp_naming_rule.private_instance_fields.required_modifiers = private
csharp_naming_rule.private_instance_fields.symbol_kind = field

csharp_naming_rule.public_methods.capitalization = pascal_case
csharp_naming_rule.public_methods.required_modifiers = public
csharp_naming_rule.public_methods.symbol_kind = method

csharp_naming_rule.private_methods.capitalization = pascal_case
csharp_naming_rule.private_methods.required_modifiers = private
csharp_naming_rule.private_methods.symbol_kind = method

csharp_naming_rule.public_properties.capitalization = pascal_case
csharp_naming_rule.public_properties.required_modifiers = public
csharp_naming_rule.public_properties.symbol_kind = property

csharp_naming_rule.private_properties.capitalization = pascal_case
csharp_naming_rule.private_properties.required_modifiers = private
csharp_naming_rule.private_properties.symbol_kind = property

csharp_naming_rule.interfaces.capitalization = pascal_case
csharp_naming_rule.interfaces.required_prefix = I
csharp_naming_rule.interfaces.symbol_kind = interface

csharp_naming_rule.classes.capitalization = pascal_case
csharp_naming_rule.classes.symbol_kind = class

csharp_naming_rule.structs.capitalization = pascal_case
csharp_naming_rule.structs.symbol_kind = struct

csharp_naming_rule.enums.capitalization = pascal_case
csharp_naming_rule.enums.symbol_kind = enum

csharp_naming_rule.constants.capitalization = pascal_case
csharp_naming_rule.constants.symbol_kind = constant

[*.{cs,csx}]
# .NET 代码风格规则
dotnet_style_readonly_field = true:suggestion
dotnet_style_require_accessibility_modifiers = for_non_interface_members:suggestion
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_explicit_tuple_names = true:suggestion
dotnet_style_prefer_inferred_tuple_names = true:suggestion
dotnet_style_prefer_inferred_anonymous_type_member_names = true:suggestion
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_prefer_conditional_expression_over_if = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_prefer_simplified_interpolation = true:suggestion
dotnet_style_prefer_simplified_boolean_expressions = true:suggestion
dotnet_style_prefer_pattern_matching = true:suggestion
dotnet_style_prefer_not_pattern = true:suggestion
dotnet_style_prefer_is_null_check = true:suggestion
dotnet_style_prefer_is_empty_check = true:suggestion
dotnet_style_throw_expression = true:suggestion
dotnet_style_prefer_null_conditional_operator = true:suggestion
dotnet_style_prefer_index_operator = true:suggestion
dotnet_style_prefer_range_operator = true:suggestion
dotnet_style_prefer_utf8_string_literals = true:suggestion
dotnet_style_prefer_readonly_struct = true:suggestion
dotnet_style_prefer_readonly_ref_struct = true:suggestion
dotnet_style_prefer_managed_pointer = true:suggestion
dotnet_style_namespace_match_folder = true:suggestion
dotnet_style_allow_multiple_blank_lines_extraction = false
dotnet_style_allow_statement_immediately_after_block = false

# 分析器规则
dotnet_diagnostic.CA1001.severity = warning    # 类型拥有可释放字段应实现 IDisposable
dotnet_diagnostic.CA1063.severity = warning    # 提供 Dispose 模式
dotnet_diagnostic.CA1303.severity = suggestion # 不要传递字面量作为参数
dotnet_diagnostic.CA1305.severity = suggestion # 指定 IFormatProvider
dotnet_diagnostic.CA1816.severity = warning    # 调用 GC.SuppressFinalize
dotnet_diagnostic.CA2000.severity = warning    # 释放对象
dotnet_diagnostic.CA2213.severity = warning    # 可释放字段应被释放
dotnet_diagnostic.CS1591.severity = warning    # 缺少 XML 注释
dotnet_diagnostic.CS8600.severity = warning    # 可空性警告
dotnet_diagnostic.CS8602.severity = warning    # 可空性警告
dotnet_diagnostic.CS8603.severity = warning    # 可空性警告
dotnet_diagnostic.CS8604.severity = warning    # 可空性警告
dotnet_diagnostic.IDE0005.severity = warning   # 移除不必要的 using
dotnet_diagnostic.IDE0008.severity = suggestion # 使用显式类型
dotnet_diagnostic.IDE0009.severity = suggestion # 使用 this.
dotnet_diagnostic.IDE0019.severity = suggestion # 使用模式匹配
dotnet_diagnostic.IDE0028.severity = suggestion # 使用集合初始化器
dotnet_diagnostic.IDE0029.severity = suggestion # 使用 null 检查
dotnet_diagnostic.IDE0039.severity = suggestion # 使用 pattern matching
dotnet_diagnostic.IDE0040.severity = warning   # 添加 accessibility modifiers
dotnet_diagnostic.IDE0044.severity = suggestion # 使字段 readonly
dotnet_diagnostic.IDE0051.severity = suggestion # 移除未使用的私有成员
dotnet_diagnostic.IDE0052.severity = suggestion # 移除未读取的私有成员
dotnet_diagnostic.IDE0055.severity = suggestion # 格式化
dotnet_diagnostic.IDE0059.severity = suggestion # 移除不必要的赋值
dotnet_diagnostic.IDE0060.severity = suggestion # 移除未使用的参数
dotnet_diagnostic.IDE0090.severity = suggestion # 使用 new()
dotnet_diagnostic.IDE0110.severity = suggestion # 可丢弃的未使用
dotnet_diagnostic.IDE0120.severity = suggestion # 简化 LINQ
dotnet_diagnostic.IDE0130.severity = warning   # 命名空间与文件夹结构不匹配
dotnet_diagnostic.IDE0150.severity = suggestion # 使用 null 检查模式
dotnet_diagnostic.IDE0160.severity = suggestion # 使用文件范围命名空间
dotnet_diagnostic.IDE0180.severity = suggestion # 使用元组解构
dotnet_diagnostic.IDE0200.severity = suggestion # 移除 lambda 表达式参数类型
dotnet_diagnostic.IDE0220.severity = suggestion # 使用 pattern matching
dotnet_diagnostic.IDE0250.severity = suggestion # 使 struct readonly
dotnet_diagnostic.IDE0251.severity = suggestion # 使用 readonly 成员
dotnet_diagnostic.IDE0290.severity = suggestion # 使用主构造函数
dotnet_diagnostic.IDE0300.severity = suggestion # 简化集合初始化
